  "contract_clauses": [
    {
      "id": "ATTR-1.1",
      "text": "Step 1: Assign each eligible beneficiary to the ACO participant (TIN/NPI) that provided the plurality of primary care services, as defined by CPT codes 99201-99215, 99381-99397, and G0438-G0439, during the most recent 12-month period.",
      "section": "Filter professional claims to qualifying CPT codes (26 codes). In Step 1, consider only PCP providers. Assign member to provider with most qualifying visits (plurality).",
      "title": "ATTR-1.1",
      "parameters": {
        "attribution_method": "plurality",
        "qualifying_cpt_codes": [
          "99201",
          "99202",
          "99203",
          "99204",
          "99205",
          "99211",
          "99212",
          "99213",
          "99214",
          "99215",
          "99381",
          "99382",
          "99383",
          "99384",
          "99385",
          "99386",
          "99387",
          "99391",
          "99392",
          "99393",
          "99394",
          "99395",
          "99396",
          "99397",
          "G0438",
          "G0439"
        ],
        "provider_filter_step1": "pcp_only",
        "lookback_months": 12
      }
    },
    {
      "id": "ATTR-1.2",
      "text": "Step 2: For beneficiaries not assigned in Step 1, assign based on the plurality of primary care services provided by any ACO participant, including specialists who rendered qualifying primary care codes.",
      "section": "For members not attributed in Step 1, expand the provider pool to all ACO participants including specialists.",
      "title": "ATTR-1.2",
      "parameters": {
        "provider_filter_step2": "all_aco_participants"
      }
    },
    {
      "id": "ATTR-1.3",
      "text": "In the event of a tie in service counts, the beneficiary shall be assigned to the provider whose most recent qualifying service was most recent in time.",
      "section": "Tiebreaker method: most recent visit. When two providers have equal qualifying visit counts, the tie is broken by the most recent qualifying service date.",
      "title": "ATTR-1.3",
      "parameters": {
        "tiebreaker": "most_recent_visit"
      }
    }
  ],
  "code_references": [
    {
      "module": "step_2_attribution",
